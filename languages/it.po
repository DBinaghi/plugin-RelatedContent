#: RelatedContentPlugin.php:322
msgid "Related Items you might want to check out"
msgstr "Documenti correlati che potresti voler controllare"

#: config_form.php:8
msgid "Items Limit"
msgstr "Limite documenti"

#: config_form.php:12
msgid "The maximum amount of related Items to be suggested."
msgstr "Il numero massimo di documenti correlati da suggerire."

#: config_form.php:20
msgid "Use Square Thumbnails"
msgstr "Usa miniature quadrate"

#: config_form.php:24
msgid "If checked, cropped square thumbnails are displayed."
msgstr "Se selezionata, verranno mostrate miniature squadrate."

#: config_form.php:32
msgid "Use Short Date"
msgstr "Usa data corta"

#: config_form.php:36
msgid "If checked, just the year (first 4 digits) will be considered for date similarity."
msgstr "Se selezionata, solo l'anno (le prime 4 cifre) verrà considerato per la similarità per data."

#: config_form.php:44
msgid "Show Item Title"
msgstr "Mostra titolo documento"

#: config_form.php:48
msgid "If checked, a truncated title is displayed below each thumbnail."
msgstr "Se selezionata, un titolo abbreviato verrà mostrato sotto ogni miniatura."

#: config_form.php:56
msgid "Exclude Items Without Image"
msgstr "Escludi documenti senza immagine"

#: config_form.php:60
msgid "If checked, Items with no associated files will not be suggested."
msgstr "Se selezionata, i documenti senza file associati non verranno suggeriti."

#: config_form.php:68
msgid "Criteria"
msgstr "Criteri"

#: config_form.php:72
msgid "The search criteria's relative weights (if blank, criteria will not be considered) and constraint rule. See the <a href=\"%s\" target=\"_blank\">plugin's documentation</a> for detailed instructions."
msgstr "I pesi relativi dei criteri di ricerca (se vuoto, il criterio non verrà considerato) e regole di vincolo. Vedere la <a href=\"%s\" target=\"_blank\">documentazione del plugin</a> per istruzioni dettagliate."

#: config_form.php:77
msgid "Criterion"
msgstr "Criterio"

#: config_form.php:78
msgid "A positive number. Higher values increase the importance of this criterion. Leave blank to ignore it."
msgstr "Un numero positivo. Valori più alti aumentano l'importanza del criterio. Lasciare vuoto per ignorarlo."

#: config_form.php:78
msgid "Weight"
msgstr "Peso"

#: config_form.php:79
msgid "If checked, only items matching this criterion will be suggested, regardless of other criteria."
msgstr "Se selezionata, verranno suggeriti solo i documenti che corrispondono a questo criterio, indipendentemente dagli altri."

#: config_form.php:79
msgid "Constraint"
msgstr "Vincolo"

#: config_form.php:80
msgid "If checked, only the first 4 characters (the year) will be used for matching. Requires \"Use Short Date\" to be enabled above."
msgstr "Se selezionata, solo i primi 4 caratteri (l'anno) verranno usati per la corrispondenza. Richiede che \"Usa data corta\" sia abilitata."

#: config_form.php:80
msgid "Is Date"
msgstr "È data"

#: config_form.php:129
msgid "Other criteria"
msgstr "Altri criteri"

#: config_form.php:133
msgid "Item Type"
msgstr "Tipologia documento"

#: config_form.php:163
msgid "Collection"
msgstr "Collezione"

#: config_form.php:193
msgid "Tags"
msgstr "Etichette"
