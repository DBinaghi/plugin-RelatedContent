#: RelatedContentPlugin.php:322
msgid "Related Items you might want to check out"
msgstr "Rilatantaj eroj vi povus interesiĝi pri"

#: config_form.php:8
msgid "Items Limit"
msgstr "Limo de eroj"

#: config_form.php:12
msgid "The maximum amount of related Items to be suggested."
msgstr "La maksimuma nombro da rilatantaj eroj por sugesti."

#: config_form.php:20
msgid "Use Square Thumbnails"
msgstr "Uzi kvadratajn bildetojn"

#: config_form.php:24
msgid "If checked, cropped square thumbnails are displayed."
msgstr "Se elektita, montriĝos kvadrataj tonditaj bildetoj."

#: config_form.php:32
msgid "Use Short Date"
msgstr "Uzi mallongan daton"

#: config_form.php:36
msgid "If checked, just the year (first 4 digits) will be considered for date similarity."
msgstr "Se elektita, nur la jaro (la unuaj 4 ciferoj) estos konsiderata por dato-simileco."

#: config_form.php:44
msgid "Show Item Title"
msgstr "Montri titolon de ero"

#: config_form.php:48
msgid "If checked, a truncated title is displayed below each thumbnail."
msgstr "Se elektita, mallongigita titolo montriĝos sub ĉiu bildeto."

#: config_form.php:56
msgid "Exclude Items Without Image"
msgstr "Ekskludi senbildajn erojn"

#: config_form.php:60
msgid "If checked, Items with no associated files will not be suggested."
msgstr "Se elektita, eroj sen asociitaj dosieroj ne estos sugestataj."

#: config_form.php:68
msgid "Criteria"
msgstr "Kriterioj"

#: config_form.php:72
msgid "The search criteria's relative weights (if blank, criteria will not be considered) and constraint rule. See the <a href=\"%s\" target=\"_blank\">plugin's documentation</a> for detailed instructions."
msgstr "La relativaj pezoj de la serĉkriterioj (se malplena, la kriterio ne estos konsiderata) kaj limiga regulo. Vidu la <a href=\"%s\" target=\"_blank\">dokumentadon de la kromprogramo</a> por detalaj instrukcioj."

#: config_form.php:77
msgid "Criterion"
msgstr "Kriterio"

#: config_form.php:78
msgid "A positive number. Higher values increase the importance of this criterion. Leave blank to ignore it."
msgstr "Pozitiva nombro. Pli altaj valoroj pliigas la gravecon de ĉi tiu kriterio. Lasu malplena por ignori ĝin."

#: config_form.php:78
msgid "Weight"
msgstr "Pezo"

#: config_form.php:79
msgid "If checked, only items matching this criterion will be suggested, regardless of other criteria."
msgstr "Se elektita, nur eroj kongruantaj kun ĉi tiu kriterio estos sugestataj, sendepende de aliaj kriterioj."

#: config_form.php:79
msgid "Constraint"
msgstr "Limo"

#: config_form.php:80
msgid "If checked, only the first 4 characters (the year) will be used for matching. Requires \"Use Short Date\" to be enabled above."
msgstr "Se elektita, nur la unuaj 4 signoj (la jaro) estos uzataj por kongruo. Postulas ke \"Uzi mallongan daton\" estu ebligita supre."

#: config_form.php:80
msgid "Is Date"
msgstr "Estas dato"

#: config_form.php:129
msgid "Other criteria"
msgstr "Aliaj kriterioj"

#: config_form.php:133
msgid "Item Type"
msgstr "Tipo de ero"

#: config_form.php:163
msgid "Collection"
msgstr "Kolekto"

#: config_form.php:193
msgid "Tags"
msgstr "Etikedoj"
